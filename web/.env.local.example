# Supabase Configuration (Public/Anon key is fine for reading if RLS is set, Service key for admin)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Cesium Ion Token (Required for 3D Globe)
# Get this from https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_TOKEN=your-cesium-ion-token
